    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.7.0",
    "redux": "^5.0.1",
    "sweetalert2": "^11.26.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
